# ---------- while loop ----------

# counting up
var i = 0;
while i < 5 {
  i = i + 1;
}
assert(i == 5, "while counts to 5");

# accumulator
var sum = 0;
var j = 1;
while j <= 10 {
  sum = sum + j;
  j = j + 1;
}
assert(sum == 55, "sum 1..10 via while");

# while false doesn't execute
var touched = false;
while false {
  touched = true;
}
assert(not touched, "while false is a no-op");

# var declared inside the body re-declares each iteration (block scoping)
var outer_sum = 0;
var k = 0;
while k < 3 {
  var local = k * 2;
  outer_sum = outer_sum + local;
  k = k + 1;
}
assert(outer_sum == 6, "loop-local var re-declares each iteration");
