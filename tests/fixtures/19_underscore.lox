# ---------- Underscore wildcard: discard binding semantics ----------

# repeated `var _ = …` does not collide
var _ = 1;
var _ = "two";
var _ = true;

# expression rhs runs for side effects (counter increments through fn call)
var counter = 0;
var bump = fn() { counter = counter + 1; return 42; };
var _ = bump();
assert(counter == 1, "var _ = expr runs side effects");

# tuple destructuring with `_` skips a member
var %(_, b) = %(1, 2);
assert(b == 2, "tuple destructure: _ skips first");

var %(a, _) = %(10, 20);
assert(a == 10, "tuple destructure: _ skips second");

# both ends discarded — purely for side-effect testing
var %(_, _) = %(99, 100);

# `for _ in …` runs the body without binding the iterator
counter = 0;
for _ in [1, 2, 3] { counter = counter + 1; }
assert(counter == 3, "for _ in array iterates");

# `for _ in map` works analogously
counter = 0;
for _ in %{"a" => 1, "b" => 2} { counter = counter + 1; }
assert(counter == 2, "for _ in map iterates");

# `_ = rhs` is accepted and discards, with side effects preserved
counter = 0;
_ = bump();
assert(counter == 1, "_ = expr runs side effects");
